# Backend API URL — set in Vercel environment variables for production
# Leave unset for local dev to route through Vite proxy to backend/dev-server
VITE_API_URL=

# Anthropic API key for Claude-powered instruction detection
# Set in Vercel dashboard for production; in .env.local for local testing
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Enable frontend-only mock API (auth & files).
# For real backend, leave unset or set to "false".
VITE_USE_MOCK_API=false
